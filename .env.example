# ═══════════════════════════════════════════════════════════════
# TIMIS/TIMIS Platform — Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL (Primary)
# ───────────────────────────────────────────────────────────────
POSTGRES_DB=timis
POSTGRES_USER=timis
POSTGRES_PASSWORD=
DATABASE_URL=postgres://timis:${POSTGRES_PASSWORD}@postgres:5432/timis
DATABASE_MAX_CONNECTIONS=20

# ───────────────────────────────────────────────────────────────
# DATABASE — MongoDB (Documents, audit logs, media metadata)
# ───────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=timis
MONGO_INITDB_ROOT_PASSWORD=
MONGO_URL=mongodb://timis:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017/timis?authSource=admin

# ───────────────────────────────────────────────────────────────
# CACHE — Redis
# ───────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ───────────────────────────────────────────────────────────────
# MESSAGE QUEUE — RabbitMQ
# ───────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=timis
RABBITMQ_DEFAULT_PASS=
RABBITMQ_URL=amqp://timis:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

# ───────────────────────────────────────────────────────────────
# OBJECT STORAGE — MinIO (S3-compatible)
# ───────────────────────────────────────────────────────────────
MINIO_ROOT_USER=timis
MINIO_ROOT_PASSWORD=                          # Min 12 characters
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_DOCUMENTS=timis-documents         # ID uploads, lease PDFs
MINIO_BUCKET_MEDIA=timis-media                 # Photos, videos
MINIO_BUCKET_EVIDENCE=timis-evidence           # Dispute evidence

# ───────────────────────────────────────────────────────────────
# AUTH — JWT & OAuth 2.0
# ───────────────────────────────────────────────────────────────
JWT_SECRET=                                   # Generate: openssl rand -hex 32
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30
OAUTH_GOOGLE_CLIENT_ID=                       # Optional: Google Sign-In
OAUTH_GOOGLE_CLIENT_SECRET=

# ───────────────────────────────────────────────────────────────
# ENCRYPTION — PII at rest (AES-256-GCM)
# ───────────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=                           # Generate: openssl rand -base64 32

# ───────────────────────────────────────────────────────────────
# M-PESA — Safaricom Daraja API
# Get from: https://developer.safaricom.co.ke
# ───────────────────────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox                     # "sandbox" or "production"
MPESA_CONSUMER_KEY=                           # From Daraja portal → App credentials
MPESA_CONSUMER_SECRET=                        # From Daraja portal → App credentials
MPESA_PASSKEY=                                # From Daraja portal → Lipa Na M-Pesa Online
MPESA_SHORTCODE=174379                        # Your Paybill number (sandbox: 174379)
MPESA_B2C_SHORTCODE=                          # For payouts (may differ from paybill)
MPESA_INITIATOR_NAME=                         # For B2C transactions
MPESA_INITIATOR_PASSWORD=                     # Encrypted security credential
MPESA_CALLBACK_URL=https://api.timis.co.ke/api/v1/mpesa/callback
MPESA_VALIDATION_URL=https://api.timis.co.ke/api/v1/mpesa/c2b/validation
MPESA_CONFIRMATION_URL=https://api.timis.co.ke/api/v1/mpesa/c2b/confirmation
MPESA_B2C_RESULT_URL=https://api.timis.co.ke/api/v1/mpesa/b2c/result
MPESA_B2C_TIMEOUT_URL=https://api.timis.co.ke/api/v1/mpesa/b2c/timeout

# ───────────────────────────────────────────────────────────────
# AI — Anthropic Claude API
# Get from: https://console.anthropic.com
# ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=                               # sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_DAILY_LIMIT_FREE=50                    # Max AI requests per org (Free plan)
CLAUDE_DAILY_LIMIT_STARTER=200
CLAUDE_DAILY_LIMIT_PRO=1000

# ───────────────────────────────────────────────────────────────
# SMS — Africa's Talking
# Get from: https://africastalking.com (sign up, create app)
# ───────────────────────────────────────────────────────────────
AT_API_KEY=                                   # From AT dashboard → Settings → API Key
AT_USERNAME=                                  # Your AT app username (sandbox: "sandbox")
AT_SENDER_ID=TIMIS                             # Registered sender ID (apply via AT dashboard)
AT_ENVIRONMENT=sandbox                        # "sandbox" or "production"

# ───────────────────────────────────────────────────────────────
# EMAIL — SendGrid
# Get from: https://sendgrid.com
# ───────────────────────────────────────────────────────────────
SENDGRID_API_KEY=                             # SG.xxxx (create in SendGrid → Settings → API Keys)
FROM_EMAIL=notifications@timis.co.ke
FROM_NAME=TIMIS

# ───────────────────────────────────────────────────────────────
# WHATSAPP — WhatsApp Business API (Optional, Phase 2)
# Get from: https://developers.facebook.com/docs/whatsapp
# ───────────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ───────────────────────────────────────────────────────────────
# KRA — iTax/eTIMS Integration (Phase 2)
# Get from: KRA eTIMS onboarding process
# ───────────────────────────────────────────────────────────────
KRA_ETIMS_BASE_URL=https://etims.kra.go.ke/api
KRA_ETIMS_DEVICE_SERIAL=
KRA_ETIMS_TIN=                                # Your Tax Identification Number
KRA_ETIMS_BRANCH_ID=00

# ───────────────────────────────────────────────────────────────
# FRONTEND — Next.js
# ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=https://api.timis.co.ke/graphql
NEXT_PUBLIC_API_URL=https://api.timis.co.ke/api/v1
NEXT_PUBLIC_WS_URL=wss://api.timis.co.ke/ws
NEXT_PUBLIC_APP_URL=https://timis.co.ke
NEXT_PUBLIC_MPESA_PAYBILL=174379              # Displayed to tenants

# ───────────────────────────────────────────────────────────────
# SERVER — Rust API
# ───────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUST_LOG=timis_api=info,tower_http=info
ENVIRONMENT=development                       # "development", "staging", "production"

# ───────────────────────────────────────────────────────────────
# NGINX / DOMAIN
# ───────────────────────────────────────────────────────────────
DOMAIN=timis.co.ke
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ───────────────────────────────────────────────────────────────
# PLATFORM — Subscription Plans (KES)
# ───────────────────────────────────────────────────────────────
PLAN_FREE_MAX_UNITS=5
PLAN_STARTER_MAX_UNITS=30
PLAN_STARTER_PRICE_KES=1500
PLAN_PRO_MAX_UNITS=100
PLAN_PRO_PRICE_KES=4000

# ───────────────────────────────────────────────────────────────
# BACKUPS
# ───────────────────────────────────────────────────────────────
BACKUP_ENCRYPTION_KEY=                        # GPG key ID or passphrase for encrypted backups
BACKUP_REMOTE_PATH=                           # s3://bucket or /remote/path for offsite
BACKUP_RETENTION_DAYS=30

# ═══════════════════════════════════════════════════════════════
# HOW TO GET EACH CREDENTIAL:
# ═══════════════════════════════════════════════════════════════
#
# M-PESA (Daraja):
#   1. Go to https://developer.safaricom.co.ke
#   2. Create account → Create App → Select "Lipa Na M-Pesa Sandbox"
#   3. Copy Consumer Key + Consumer Secret
#   4. For production: apply for Go-Live (requires business registration)
#   5. Passkey: provided after Go-Live approval
#
# CLAUDE (Anthropic):
#   1. Go to https://console.anthropic.com
#   2. Sign up → Create API key
#   3. Add billing (pay-per-token)
#
# AFRICA'S TALKING:
#   1. Go to https://africastalking.com
#   2. Sign up → Create app
#   3. Go to Settings → Generate API Key
#   4. For production: fund your AT wallet (KES)
#   5. Sender ID: apply via AT dashboard (takes ~3 days approval)
#
# SENDGRID:
#   1. Go to https://sendgrid.com → Sign up
#   2. Settings → API Keys → Create Key (Full Access)
#   3. Verify sender domain (DNS records for timis.co.ke)
#
# KRA eTIMS:
#   1. Register on KRA iTax portal
#   2. Apply for eTIMS device/virtual device
#   3. Complete onboarding process with KRA
#   4. Receive device serial and credentials
#
# SSL CERTIFICATE:
#   1. Use Let's Encrypt (free): certbot certonly --nginx -d timis.co.ke -d *.timis.co.ke
#   2. Or purchase from provider (Comodo, DigiCert)
#
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# AI — Flexible Provider Configuration
# ───────────────────────────────────────────────────────────────
# AI_PROVIDER options: "anthropic", "groq", "together", "openai", "ollama"
# Switch between paid (Claude/GPT-4) and free (Groq Llama) by changing these 3 vars:
#
# FREE OPTION — Groq (free tier: 30 req/min):
#   AI_PROVIDER=groq
#   AI_API_KEY=gsk_your_groq_key        # Get from: https://console.groq.com
#   AI_MODEL=llama-3.1-8b-instant
#   AI_BASE_URL=https://api.groq.com/openai/v1
#
# FREE OPTION — Together AI (free tier available):
#   AI_PROVIDER=together
#   AI_API_KEY=your_together_key         # Get from: https://api.together.xyz
#   AI_MODEL=meta-llama/Llama-3-8b-chat-hf
#   AI_BASE_URL=https://api.together.xyz/v1
#
# PAID — Anthropic Claude:
#   AI_PROVIDER=anthropic
#   AI_API_KEY=sk-ant-your-key           # Get from: https://console.anthropic.com
#   AI_MODEL=claude-sonnet-4-20250514
#   AI_BASE_URL=                          # Not needed for Anthropic
#
# PAID — OpenAI:
#   AI_PROVIDER=openai
#   AI_API_KEY=sk-your-openai-key
#   AI_MODEL=gpt-4o-mini
#   AI_BASE_URL=https://api.openai.com/v1
#
# LOCAL — Ollama (free, runs locally):
#   AI_PROVIDER=ollama
#   AI_API_KEY=ollama
#   AI_MODEL=llama3
#   AI_BASE_URL=http://localhost:11434/v1

AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MAX_TOKENS=2048
